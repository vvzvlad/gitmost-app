{
  // VSCode tasks for this workspace. Run via: Terminal -> Run Task,
  // or the default build shortcut Cmd+Shift+B (mapped to "make run" below).
  "version": "2.0.0",
  "tasks": [
    {
      "label": "make run",
      "detail": "Build and launch gitmost.app",
      "type": "shell",
      "command": "make run",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "never",
        "panel": "shared",
        "clear": true,
        "focus": false
      },
      "problemMatcher": []
    },
    {
      "label": "make build",
      "detail": "Release build of gitmost.app",
      "type": "shell",
      "command": "make build",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    },
    {
      "label": "make test",
      "detail": "Run unit tests (swift test)",
      "type": "shell",
      "command": "make test",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}
